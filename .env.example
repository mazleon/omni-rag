# Copy this file to .env and fill in values for local development.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://omnirag:omnirag@localhost:5432/omnirag

# ── Vector Store ──────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                   # leave empty for local

# ── Cache / Queue ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI APIs ───────────────────────────────────────────────────────────────────
COHERE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                   # optional, used as LiteLLM fallback

# ── Object Storage ────────────────────────────────────────────────────────────
S3_BUCKET=omnirag-documents
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Observability ─────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── App ───────────────────────────────────────────────────────────────────────
ENV=development                    # development | staging | production
JWT_SECRET=change-me-in-production
