# Copy this file to .env and fill in values for local development.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://omnirag:omnirag@localhost:5432/omnirag

# ── Vector Store ──────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                       # leave empty for local

# ── Cache / Queue ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI APIs ───────────────────────────────────────────────────────────────────
COHERE_API_KEY=                        # embeddings (embed-v4) + reranker (rerank-v3.5)

# LLM via OpenRouter (https://openrouter.ai) — unified access to Claude, GPT-4o, Llama, etc.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Default model — any model slug from openrouter.ai/models
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-sonnet

# ── Object Storage (Supabase Storage) ────────────────────────────────────────
# Supabase project settings → Storage → S3 connection details
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=             # Settings → API → service_role secret
SUPABASE_STORAGE_BUCKET=omnirag-documents

# Supabase Storage also exposes an S3-compatible endpoint (use with boto3/aiobotocore)
SUPABASE_S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
SUPABASE_S3_ACCESS_KEY=                # Settings → Storage → S3 Access Keys
SUPABASE_S3_SECRET_KEY=
SUPABASE_S3_REGION=ap-southeast-1      # set to your Supabase project region

# ── Observability ─────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── App ───────────────────────────────────────────────────────────────────────
ENV=development                        # development | staging | production
JWT_SECRET=change-me-in-production
